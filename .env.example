# --- Database ---
DATABASE_URL=postgresql+asyncpg://trader:trader@localhost:5432/trading
SYNC_DATABASE_URL=postgresql://trader:trader@localhost:5432/trading

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Alpaca ---
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Reddit ---
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=stock-trading-assistant/0.1

# --- NewsAPI ---
NEWSAPI_KEY=your_newsapi_key

# --- Finnhub (real-time news, earnings calendar, sentiment) ---
FINNHUB_API_KEY=your_finnhub_key

# --- NewsData.io (90k+ global sources) ---
NEWSDATA_API_KEY=your_newsdata_key

# --- QuiverQuant ---
QUIVERQUANT_API_KEY=your_quiverquant_key

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=your_anthropic_key

# --- Google (Gemini) ---
GEMINI_API_KEY=your_gemini_key

# --- App ---
SECRET_KEY=change-me-to-random-secret
ENVIRONMENT=development
LOG_LEVEL=INFO
